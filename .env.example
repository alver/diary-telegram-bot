# ── Telegram ──────────────────────────────────────────────────────────────────
# Get this from @BotFather after creating a bot with /newbot
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to interact with the bot
# Leave empty to allow everyone (not recommended)
ALLOWED_USER_IDS=

# Your Telegram user ID — the bot sends scheduled mood checks here
# Find yours by messaging @userinfobot
DIARY_CHAT_ID=

# ── Storage ───────────────────────────────────────────────────────────────────
AUDIO_DIR=storage/audio
ARCHIVE_DIR=storage/archive
DIARY_DIR=storage/diary
MOOD_CSV=storage/mood.csv
SLEEP_CSV=storage/sleep.csv

# ── Transcription ─────────────────────────────────────────────────────────────
# Currently supported: whisper_local
TRANSCRIPTION_SERVICE=whisper_local

# Path to a ggml model file (e.g. ggml-large-v3-q5_0.bin)
WHISPER_MODEL_PATH=

# Path to the whisper.cpp binary
# On Windows: whisper.exe   On Linux/macOS: whisper (or an absolute path)
WHISPER_EXE=whisper

# Language code passed to whisper (-l flag)
WHISPER_LANG=ru

# Max seconds for a single whisper run. Leave empty or set 0 for no limit
# (recommended on CPU — long recordings can take hours).
WHISPER_TIMEOUT=

# Voice Activity Detection (Silero VAD via whisper.cpp).
# Skips silent regions before transcription — large speedup for diary-style
# recordings with long pauses. Requires a VAD model file.
# Download: ./models/download-vad-model.sh silero-v6.2.0
WHISPER_VAD=false
WHISPER_VAD_MODEL=
# Optional tunables (leave empty to use whisper.cpp defaults)
WHISPER_VAD_THRESHOLD=
WHISPER_VAD_MIN_SILENCE_MS=
WHISPER_VAD_SPEECH_PAD_MS=

# Path to the ffmpeg binary. Leave as "ffmpeg" to use PATH, or give an absolute path.
FFMPEG_EXE=ffmpeg

# ── Mood & sleep schedule ─────────────────────────────────────────────────────
# Base times for mood pings (24h local). Each ping fires at a random moment
# within ±PING_WINDOW_MINUTES of the base time (rerolled daily).
MOOD_PING_TIMES=09:00,15:00,21:00

# Randomization window around each base time, in minutes
PING_WINDOW_MINUTES=90

# Minimum enforced spacing between consecutive pings (re-rolled if violated)
MIN_GAP_BETWEEN_PINGS_MINUTES=120

# How long a prompt remains answerable; late taps are rejected
RESPONSE_TIMEOUT_MINUTES=120

# Fixed time for the daily sleep-quality question (not randomized)
SLEEP_QUESTION_TIME=09:00
